{
  "name": "notified.sh-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "notified.sh — Claude Code limit notifications via Telegram. Monorepo root.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@9.1.2",
  "scripts": {
    "build": "pnpm -r run build",
    "sync-plugin": "node packages/plugin/scripts/sync-cli.mjs",
    "release": "pnpm build && pnpm sync-plugin",
    "check:plugin-bundle": "pnpm release && git diff --exit-code -- packages/plugin/dist",
    "test": "pnpm -r run test",
    "lint": "eslint \"packages/**/*.ts\"",
    "format": "prettier --write \"packages/**/*.{ts,json,md}\" \"docs/**/*.md\" \"README.md\"",
    "typecheck": "tsc -b --pretty",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo coverage"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
