      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "LIMIT DETECTION: Claude writes a rate_limit line to JSONL. The StopFailure hook runs notified _hook stop. The hook parses reset time, dedupes locally, then POSTs /v1/notify.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LIMIT DETECTION: Claude writes a rate_limit line to JSONL. The StopFailure hook runs notified _hook stop. The hook parses reset time, dedupes locally, then POSTs /v1/notify.",
      "lineHeight": 1.25,
      "baseline": 23
    },
