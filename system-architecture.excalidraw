      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Local files: config.json stores api_base, device_token, child_bot_username. state.json deduplicates submitted notifications. Claude settings.json installs StopFailure/rate_limit hook.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Local files: config.json stores api_base, device_token, child_bot_username. state.json deduplicates submitted notifications. Claude settings.json installs StopFailure/rate_limit hook.",
