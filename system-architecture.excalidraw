      "updated": 1,
      "link": null,
      "locked": false,
      "text": "DELIVERY: Cloudflare cron runs dispatch. Worker claims due pending notifications from D1, decrypts the child bot token, calls Telegram sendMessage, then marks sent/retry/failed.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
