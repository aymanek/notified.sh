      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "PAIRING: CLI creates a temporary session. Telegram creates a child bot. Worker saves encrypted bot token in D1. User sends /start. CLI receives a one-time device token and installs the Claude hook.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PAIRING: CLI creates a temporary session. Telegram creates a child bot. Worker saves encrypted bot token in D1. User sends /start. CLI receives a one-time device token and installs the Claude hook.",
      "lineHeight": 1.25,
      "baseline": 23
    },
